# Application
NODE_ENV=development
PORT=3000

# CORS — comma-separated list of allowed origins (must be exact for cookies/credentials)
CORS_ORIGIN=http://localhost:5173

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/easygenerator

# JWT — access token (short-lived, returned in the response body)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN_MINUTES=15

# JWT — refresh token (long-lived, stored in an HttpOnly cookie, rotated on use)
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Refresh-token cookie. Keep COOKIE_SECURE=false for local HTTP; set true behind HTTPS.
# Use COOKIE_SAMESITE=none (with COOKIE_SECURE=true) when the API and web app are on different sites.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Rate limiting (window in milliseconds, max requests per window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
